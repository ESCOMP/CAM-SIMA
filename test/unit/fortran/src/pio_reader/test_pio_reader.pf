@test
subroutine final_test()
    use funit

    use mpi, only: mpi_finalize, MPI_SUCCESS

    integer :: mpi_ierr

    ! Shutdown MPI:
    ! NOTE: This must be done for the last test in the test suite.
    call mpi_finalize(mpi_ierr)

    @assertEqual(MPI_SUCCESS, mpi_ierr)

end subroutine final_test
