@test
subroutine test_pio_open_file()
    use funit

    use pio,           only: file_desc_t
    use pio,           only: PIO_NOWRITE
    use mpi,           only: mpi_init
    use mpi,           only: mpi_finalize
    use cam_pio_utils, only: cam_pio_openfile

    character(len=*), parameter :: fname = &
    '../../../rrtmgp-data/rrtmgp-gas-sw-g112.nc'

    type(file_desc_t) :: file_handle

    integer :: ierr

    !Initialize MPI:
    call mpi_init(ierr)

    !Open file:
    call cam_pio_openfile(file_handle, fname, PIO_NOWRITE)

    @assertGreaterThan(file_handle%fh, 0)

    call MPI_Finalize(ierr)
end subroutine test_pio_open_file