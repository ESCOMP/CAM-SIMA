[ccpp-table-properties]
  name = read_water_refindex
  type = module

[ccpp-arg-table]
  name  = read_water_refindex
  type  = module
[ crefwsw ]
  standard_name = water_refractive_index_for_shortwave_radiation
  units = 1
  type = complex | kind = kind_phys
  dimensions = (number_of_bands_for_shortwave_radiation)
[ crefwlw ]
  standard_name = water_refractive_index_for_longwave_radiation
  units = 1
  type = complex | kind = kind_phys
  dimensions = (number_of_bands_for_longwave_radiation)
